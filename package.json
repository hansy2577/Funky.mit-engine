{
  "name": "Funky-mit engine",
  "version": "1.3.4",
  "author": "hansy2577",
  "description": "fnf pysch engine but remade in HTML JS !1!!1!",

  "keywords": ["game", "rhythm", "music","friday night funkin'"],
  "license": "MIT",
  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-packager . Funky_mit_engine --platform=win32 --arch=x64 --out=dist --overwrite"
  },

  "devDependencies": {
    "electron": "^42.4.0",
    "electron-packager": "^17.1.2"
  },


  "build": {
    "icon": "icon.ico",
    "appId": "com.h.project",
    "productName": "Funky.mit-engine",
    "directories": {
      "buildResources": "assets",
      "output": "output-exe"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "icon.ico"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Funky.mit-engine"
    }
  }
}
